---
interface Heading {
  id: string
  level: number
  text: string
}

interface Props {
  headings: Heading[]
}

const { headings } = Astro.props
---

{
  headings.length > 0 && (
    <nav class="toc">
      <ul>
        {headings.map((h) => (
          <li class={h.level === 2 ? "level-2" : "level-3"}>
            <a href={`#${h.id}`}>{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  .toc {
    min-width: 200px;
    width: 100%;
    max-width: 240px;
    position: sticky;
    top: 2rem;
    height: min-content;
    max-height: calc(100vh - 24px);
    overflow-y: auto;
    background: var(--color-bg);
    color: var(--color-accent);
    padding: 0;
    flex-shrink: 0;
  }
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  li {
    margin: 0.5rem 0;
  }
  .level-3 {
    margin-left: 0.75rem;
  }
  a {
    font-size: 14px;
    color: var(--color-accent);
    text-decoration: underline;
  }
  a:hover {
    opacity: 0.8;
  }
  @media (max-width: 640px) {
    .toc {
      display: none;
    }
  }
</style>
